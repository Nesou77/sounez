# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.sounez.com
APP_URL=https://www.sounez.com

# ── Database (Prisma) ─────────────────────────────────────────────────────────
# Local SQLite:
DATABASE_URL="file:./dev.db"
# Production PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sounez?schema=public"

# ── Comment moderation (server-only) ───────────────────────────────────────────
ADMIN_MODERATION_TOKEN=replace-with-secure-token

# ── Google AdSense (Auto Ads) ──────────────────────────────────────────────────
# Full ca-pub- publisher ID. Leave the placeholder value below (or unset) until you
# have a real ID — never commit a fake one.
# TODO(owner): replace with your real ca-pub-... ID once assigned.
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXXX
# The AdSense ad script does NOT load unless this is exactly "true", even if
# NEXT_PUBLIC_ADSENSE_PUB_ID is set. The site-ownership meta tag still renders either way,
# so AdSense can verify the domain before you decide to turn ads on.
# Keep this "false" until: (1) AdSense has approved the site, and (2) a Google-certified
# CMP / GDPR message is in place for EEA, UK, and Switzerland visitors.
NEXT_PUBLIC_ADSENSE_ENABLED=false
# Per-placement ad unit ("data-ad-slot") IDs for manual <AdSlot> placements (see
# components/AdSlot.tsx). Each one is created in the AdSense dashboard after approval.
# Leave unset to keep that placement invisible — an unset slot ID renders nothing rather
# than falling back to a fabricated one.
# TODO(owner): create an in-article ad unit in AdSense and paste its slot ID here.
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_INARTICLE=

# ── Google AI Studio (Gemini) ──────────────────────────────────────────────────
# Get your key at https://aistudio.google.com
# NEVER use NEXT_PUBLIC_ prefix — this key must stay server-side only.
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── Background Remover (on-device AI) ─────────────────────────────────────────
# CDN base URL for @imgly/background-removal WASM + model files.
# Must match the exact version installed in package.json (check with: npm ls @imgly/background-removal).
# Without this, the on-device AI fallback cannot load its model and will fail silently.
NEXT_PUBLIC_BG_REMOVAL_CDN=https://staticimgly.com/@imgly/background-removal-data/1.7.0/dist/

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@sounez.com
RECIPIENT_EMAIL=

# ── reCAPTCHA ──────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Analytics ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
