# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.sounez.com
APP_URL=https://www.sounez.com

# ── Google AdSense ─────────────────────────────────────────────────────────────
# Publisher ID (required for any ads to show)
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXXX

# Per-placement slot IDs — create one ad unit per placement in your AdSense account.
# Leave empty to show a placeholder instead of a real ad.
NEXT_PUBLIC_ADSENSE_SLOT_HOME_MIDDLE=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_AFTER_WIDGET=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_TOOL_BOTTOM=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_MIDDLE=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_BOTTOM=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_BLOG_SIDEBAR=XXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT_TOOLS_PAGE=XXXXXXXXXX

# ── Google AI Studio (Gemini) ──────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# NEVER use NEXT_PUBLIC_ prefix — this key must stay server-side only.
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@sounez.com
RECIPIENT_EMAIL=

# ── reCAPTCHA ──────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Analytics ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
