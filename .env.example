# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.sounez.com
APP_URL=https://www.sounez.com

# ── Google AdSense (Auto Ads) ──────────────────────────────────────────────────
# Only the publisher ID is needed. Auto Ads handles placement automatically.
# Enable Auto Ads in your AdSense dashboard: https://www.google.com/adsense
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXXX

# ── Google AI Studio (Gemini) ──────────────────────────────────────────────────
# Get your key at https://aistudio.google.com/app/apikey
# NEVER use NEXT_PUBLIC_ prefix — this key must stay server-side only.
GEMINI_API_KEY=your_google_ai_studio_api_key
GEMINI_MODEL=gemini-2.5-flash

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@sounez.com
RECIPIENT_EMAIL=

# ── reCAPTCHA ──────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=

# ── Analytics ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GTM_ID=
