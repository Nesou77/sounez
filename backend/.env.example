# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend + api subdomain)
ALLOWED_ORIGINS=https://www.sounez.com,https://sounez.com,https://api.sounez.com

# ── LibreOffice ───────────────────────────────────────────────────────────────
# Path to the soffice binary. Auto-detected if left empty.
# Docker image sets this automatically. Override only if needed.
LIBREOFFICE_PATH=

# ── Temp files ────────────────────────────────────────────────────────────────
# Directory for temporary upload/conversion files (defaults to OS temp dir)
TEMP_DIR=

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=20
