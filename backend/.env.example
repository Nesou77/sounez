# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Vercel frontend URL)
ALLOWED_ORIGINS=https://www.sounez.com,https://sounez.com

# ── Security ──────────────────────────────────────────────────────────────────
# Optional secret for request signing (leave empty to disable)
API_SECRET=
